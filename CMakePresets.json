{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
  "configurePresets": [
    {
      "name": "vs2026",
      "displayName": "VS2026 (common toolchain settings)",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "toolset": "v145",
      "cacheVariables": { "CMAKE_POLICY_DEFAULT_CMP0091": "NEW" }
    },
    {
      "name": "sil-vs2026",
      "displayName": "SIL vs2026",
      "inherits": "vs2026",
      "binaryDir": "${sourceDir}/build-sil-vs2026",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build-sil-vs2026/conan_toolchain.cmake",
        "TARGET_TYPE": "sil",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "gtest-vs2026",
      "displayName": "GTest vs2026",
      "inherits": "vs2026",
      "binaryDir": "${sourceDir}/build-gtest-vs2026",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build-gtest-vs2026/conan_toolchain.cmake",
        "TARGET_TYPE": "sil",
        "BUILD_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "sil-vs2026", "configurePreset": "sil-vs2026", "configuration": "Release" },
    { "name": "gtest-vs2026", "configurePreset": "gtest-vs2026", "configuration": "Release" }
  ],
  "testPresets": [
    {
      "name": "gtest-vs2026",
      "configurePreset": "gtest-vs2026",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
